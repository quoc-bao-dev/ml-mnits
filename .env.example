# =========================================================================
# CẤU HÌNH BỘ DỮ LIỆU HUẤN LUYỆN MNIST (MNIST DATASET CONFIGURATION)
# =========================================================================

# 1. Số lượng mẫu huấn luyện (Training dataset size)
# - Giá trị tối đa (Max): 60000 mẫu (toàn bộ tập train MNIST).
# - Giá trị khuyên dùng (Recommended): 1000 - 5000 mẫu để tối ưu tốc độ chạy trên CPU.
# - Lưu ý: Huấn luyện mạng CNN thuần NumPy không có tăng tốc GPU (CUDA) sẽ mất
#   khoảng 1-3 giây mỗi 100 ảnh trên CPU hiện đại. Nếu cấu hình 60000 mẫu sẽ mất rất nhiều thời gian.
MNIST_NUM_TRAIN=10000

# 2. Số lượng mẫu kiểm thử (Test dataset size)
# - Giá trị tối đa (Max): 10000 mẫu (toàn bộ tập test MNIST).
# - Giá trị khuyên dùng (Recommended): 500 - 1000 mẫu.
MNIST_NUM_TEST=1000
